{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "setting"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "core:tray:default",
    "core:tray:allow-new",
    "core:tray:allow-set-menu",
    "core:tray:allow-set-icon",
    "core:menu:default",
    "core:menu:allow-new",
    "core:app:allow-default-window-icon",
    "core:tray:allow-set-show-menu-on-left-click",
    "core:menu:allow-create-default",
    "core:event:allow-emit-to",
    "core:event:allow-listen",
    "core:window:allow-get-all-windows",
    "core:window:allow-set-size",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.jdjygold.com/gw/generic/hj/h5/m/latestPrice",
          "method": "GET",
          "allow-fetch-read-body": true
        },
        {
          "url": "https://api.jdjygold.com/gw2/generic/jrm/h5/m/stdLatestPrice",
          "method": "POST",
          "allow-fetch-read-body": true
        },
        {
          "url": "https://api.jdjygold.com/gw2/generic/jrm/h5/m/icbcLatestPrice",
          "method": "POST",
          "allow-fetch-read-body": true
        }
      ]
    },
    "http:default",
    "websocket:default",
    "http:default"
  ]
}